"""
bronze_layer.py
===============
Bronze layer — raw ingestion as pure functions.

Each function has one job. No classes, no state.
FrequencyChecker logic lives in two small functions: is_due / mark_ingested.
BronzeReader logic lives in ingest_provider.

Adding a new provider requires only new entries in config.py.
"""

import json
from datetime import datetime
from pathlib import Path

import pandas as pd

from config import (
    BRONZE_PATHS,
    CONTROL_DIR,
    FREQUENCIES,
    INPUT_PATHS,
    LOG_PATH,
    PROVIDERS,
    TODAY,
)


# ---------------------------------------------------------------------------
# Frequency control
# ---------------------------------------------------------------------------

def _load_log(log_path: Path = LOG_PATH) -> dict:
    """Loads the ingestion control log from disk.

    Returns an empty dict when the file is absent or corrupt,
    triggering first-run behaviour for all providers.

    Args:
        log_path: Path to the JSON log file.

    Returns:
        Dict mapping provider keys to ISO date strings.
    """
    if not log_path.exists():
        return {}
    try:
        return json.loads(log_path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return {}


def _save_log(log: dict, log_path: Path = LOG_PATH) -> None:
    """Persists the control log to disk.

    Args:
        log: Full log dict to serialise.
        log_path: Destination path.
    """
    CONTROL_DIR.mkdir(parents=True, exist_ok=True)
    log_path.write_text(json.dumps(log, indent=2), encoding="utf-8")


def is_due(provider_key: str, log_path: Path = LOG_PATH) -> bool:
    """Returns True if the provider should be ingested today.

    A provider is due when it has no prior record (first run) or when
    the days elapsed since last ingestion >= its configured frequency.

    Args:
        provider_key: Key identifying the provider.
        log_path: Path to the control log (injectable for tests).

    Returns:
        True if ingestion should proceed; False to skip.
    """
    log = _load_log(log_path)

    if provider_key not in log:
        return True

    last_date    = datetime.strptime(log[provider_key], "%Y-%m-%d").date()
    today        = datetime.strptime(TODAY, "%Y-%m-%d").date()
    elapsed_days = (today - last_date).days
    return elapsed_days >= FREQUENCIES[provider_key]


def mark_ingested(provider_key: str, log_path: Path = LOG_PATH) -> None:
    """Records today as the last successful ingestion date.

    Must be called only after a confirmed successful write so a failed
    run does not advance the provider's schedule.

    Args:
        provider_key: Key identifying the provider.
        log_path: Path to the control log (injectable for tests).
    """
    log = _load_log(log_path)
    log[provider_key] = TODAY
    _save_log(log, log_path)


# ---------------------------------------------------------------------------
# Reading
# ---------------------------------------------------------------------------

def _read_csv(provider_key: str) -> pd.DataFrame:
    """Reads a CSV source file with all columns forced to str.

    Args:
        provider_key: Key used to resolve the file path.

    Returns:
        DataFrame with every column as object dtype.
    """
    return pd.read_csv(INPUT_PATHS[provider_key], dtype=str)


def _read_json(provider_key: str) -> pd.DataFrame:
    """Reads a JSON array source file with all columns forced to str.

    pd.read_json infers types by default; astype(str) enforces the
    all-string Bronze contract after loading.

    Args:
        provider_key: Key used to resolve the file path.

    Returns:
        DataFrame with every column as object dtype.
    """
    return pd.read_json(INPUT_PATHS[provider_key], dtype=False).astype(str)


def _read(provider_key: str) -> pd.DataFrame:
    """Dispatches to the correct reader based on file format.

    Args:
        provider_key: Key identifying the provider.

    Returns:
        Raw DataFrame with all fields as str.

    Raises:
        ValueError: If provider_key is not recognised.
    """
    readers = {
        "provider1":               _read_csv,
        "provider2":               _read_json,
        "provider3_domestic":      _read_csv,
        "provider3_international": _read_csv,
        "provider3_financials":    _read_csv,
    }
    if provider_key not in readers:
        raise ValueError(f"Unknown provider key: '{provider_key}'")
    return readers[provider_key](provider_key)


# ---------------------------------------------------------------------------
# Writing
# ---------------------------------------------------------------------------

def _write_bronze(df: pd.DataFrame, provider_key: str, today: str = TODAY) -> None:
    """Writes the DataFrame as a date-partitioned CSV.

    Folder structure:
        output/bronze/<provider>/ingestion_date=YYYY-MM-DD/<provider>.csv

    Args:
        df: Raw DataFrame (all str columns + ingestion_date).
        provider_key: Used to resolve the Bronze root path.
        today: Date string used for the partition folder name.
    """
    partition_dir = BRONZE_PATHS[provider_key] / f"ingestion_date={today}"
    partition_dir.mkdir(parents=True, exist_ok=True)
    df.to_csv(partition_dir / f"{provider_key}.csv", index=False, encoding="utf-8")


# ---------------------------------------------------------------------------
# Public API
# ---------------------------------------------------------------------------

def ingest_provider(
    provider_key: str,
    log_path: Path = LOG_PATH,
    today: str = TODAY,
) -> pd.DataFrame | None:
    """Ingests one provider file into Bronze if it is due today.

    Args:
        provider_key: Key identifying the provider.
        log_path: Path to the control log (injectable for tests).
        today: Ingestion date string (injectable for tests).

    Returns:
        The ingested DataFrame when processed, or None when skipped.

    Raises:
        ValueError: If provider_key is not recognised.
    """
    if not is_due(provider_key, log_path):
        print(f"[{provider_key}] Skipped — not due today.")
        return None

    df = _read(provider_key)
    df = df.copy()
    df["ingestion_date"] = today
    _write_bronze(df, provider_key, today)

    # Mark only after a successful write
    mark_ingested(provider_key, log_path)
    print(f"[{provider_key}] Ingested → Bronze.")
    return df


def run_bronze(log_path: Path = LOG_PATH) -> dict[str, pd.DataFrame | None]:
    """Runs the Bronze ingestion layer for all providers.

    Args:
        log_path: Path to the control log (injectable for tests).

    Returns:
        Dict mapping each provider key to its DataFrame or None.
    """
    print("\n🥉 Bronze layer — starting ingestion\n")

    results = {key: ingest_provider(key, log_path) for key in PROVIDERS}

    executed = [k for k, v in results.items() if v is not None]
    skipped  = [k for k, v in results.items() if v is None]

    print("\n── Bronze summary ──────────────────────────────────")
    print(f"Executed ({len(executed)}): {', '.join(executed) or '—'}")
    print(f"Skipped  ({len(skipped)}):  {', '.join(skipped)  or '—'}")
    return results
